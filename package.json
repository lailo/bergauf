{
  "name": "bergauf",
  "version": "1.0.0",
  "description": "MCP server for planning hikes in Switzerland — Wanderland routes, elevation, weather, public transport.",
  "type": "module",
  "bin": {
    "bergauf": "./dist/bergauf"
  },
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bunx @modelcontextprotocol/inspector bun run src/index.ts",
    "dev:stdio": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "build": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:windows-x64",
    "build:darwin-arm64": "bun build --compile --minify --target=bun-darwin-arm64 ./src/index.ts --outfile dist/bergauf-darwin-arm64",
    "build:darwin-x64": "bun build --compile --minify --target=bun-darwin-x64   ./src/index.ts --outfile dist/bergauf-darwin-x64",
    "build:linux-x64": "bun build --compile --minify --target=bun-linux-x64    ./src/index.ts --outfile dist/bergauf-linux-x64",
    "build:linux-arm64": "bun build --compile --minify --target=bun-linux-arm64  ./src/index.ts --outfile dist/bergauf-linux-arm64",
    "build:windows-x64": "bun build --compile --minify --target=bun-windows-x64  ./src/index.ts --outfile dist/bergauf-windows-x64.exe"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "license": "SEE LICENSE IN LICENSE"
}
